---
/**
 * HomeNav.astro — Microapp Global Navigation
 *
 * Desktop (lg+):
 *   Logo | Tools mega-menu | Globe dropdown | Login | Sign up
 *
 * Mobile (<lg):
 *   Logo | Globe | Hamburger
 *   Drawer: Accordion categories → Language picker → Auth CTA
 */
import NavAuthIsland from "./NavAuthIsland";
import AuthModal from "./AuthModal";
import LanguageSwitcher from "./LanguageSwitcher";
import { localizeUrl, useTranslations } from "../i18n/utils";
import { type Locale } from "../i18n/config";

interface Props {
  lang?: Locale;
}
const { lang = "en" } = Astro.props;

const t = await useTranslations(lang);

// Helper: localize a URL for the current language
const l = (path: string) => localizeUrl(path, lang);

const logoWebpUrl = "/images/microapp-logo-optimized.webp";
const logoPngUrl  = "/images/microapp-logo-optimized.png";

const catIcons = ["T", "#", "⏱", "⚡", "</>", "✍", "🎨"];

const megaMenu = [
  {
    category: t("common.nav.megaMenu.categories.textTools"),
    href: l("/categories/text-tools"),
    color: "#E8F5EE",
    iconColor: "#1B6B45",
    tools: [
      { label: t("common.nav.megaMenu.tools.wordCounter"),      href: l("/word-counter") },
      { label: t("common.nav.megaMenu.tools.characterCounter"), href: l("/character-counter") },
      { label: t("common.nav.megaMenu.tools.textRepeater"),     href: l("/text-repeater") },
      { label: t("common.nav.megaMenu.tools.sortLines"),        href: l("/sort-lines") },
      { label: t("common.nav.megaMenu.tools.textDiff"),         href: l("/text-diff-checker") },
      { label: t("common.nav.megaMenu.tools.removeDuplicates"), href: l("/remove-duplicate-lines") },
    ],
  },
  {
    category: t("common.nav.megaMenu.categories.numbers"),
    href: l("/categories/number-calculators"),
    color: "#FFF0F0",
    iconColor: "#E05252",
    tools: [
      { label: t("common.nav.megaMenu.tools.percentageCalc"),  href: l("/percentage-calculator") },
      { label: t("common.nav.megaMenu.tools.unitConverter"),   href: l("/unit-converter") },
      { label: t("common.nav.megaMenu.tools.tipCalculator"),   href: l("/tip-calculator") },
      { label: t("common.nav.megaMenu.tools.loanCalculator"),  href: l("/loan-calculator") },
      { label: t("common.nav.megaMenu.tools.discountCalc"),    href: l("/discount-calculator") },
      { label: t("common.nav.megaMenu.tools.gpaCalculator"),   href: l("/gpa-calculator") },
    ],
  },
  {
    category: t("common.nav.megaMenu.categories.timeDate"),
    href: l("/categories/time-date-tools"),
    color: "#F5F0FF",
    iconColor: "#7C3AED",
    tools: [
      { label: t("common.nav.megaMenu.tools.ageCalculator"),  href: l("/age-calculator") },
      { label: t("common.nav.megaMenu.tools.daysBetween"),    href: l("/days-between") },
      { label: t("common.nav.megaMenu.tools.ageDifference"),  href: l("/age-difference-calculator") },
    ],
  },
  {
    category: t("common.nav.megaMenu.categories.generators"),
    href: l("/categories/generators"),
    color: "#FFF9E0",
    iconColor: "#B8860B",
    tools: [
      { label: t("common.nav.megaMenu.tools.passwordGen"),  href: l("/password-generator") },
      { label: t("common.nav.megaMenu.tools.loremIpsum"),   href: l("/lorem-ipsum") },
      { label: t("common.nav.megaMenu.tools.randomNumber"), href: l("/random-number-generator") },
      { label: t("common.nav.megaMenu.tools.coinFlip"),     href: l("/coin-flip") },
      { label: t("common.nav.megaMenu.tools.diceRoller"),   href: l("/dice-roller") },
      { label: t("common.nav.megaMenu.tools.randomName"),   href: l("/random-name-generator") },
    ],
  },
  {
    category: t("common.nav.megaMenu.categories.devTools"),
    href: l("/categories/dev-tools"),
    color: "#F0F4FF",
    iconColor: "#4F6EF7",
    tools: [
      { label: t("common.nav.megaMenu.tools.jsonFormatter"),  href: l("/json-formatter") },
      { label: t("common.nav.megaMenu.tools.base64Tool"),     href: l("/base64") },
      { label: t("common.nav.megaMenu.tools.qrCodeReader"),   href: l("/qr-code-reader") },
      { label: t("common.nav.megaMenu.tools.curlBuilder"),    href: l("/curl-builder") },
      { label: t("common.nav.megaMenu.tools.sha256Gen"),      href: l("/sha256-generator") },
      { label: t("common.nav.megaMenu.tools.markdownToHtml"), href: l("/markdown-to-html") },
    ],
  },
  {
    category: t("common.nav.megaMenu.categories.writingAI"),
    href: l("/categories/writing-ai"),
    color: "#F0F8FF",
    iconColor: "#2563EB",
    tools: [
      { label: t("common.nav.megaMenu.tools.aiBioGen"),        href: l("/ai-bio-generator") },
      { label: t("common.nav.megaMenu.tools.paraphrasingTool"),href: l("/paraphrasing-tool") },
      { label: t("common.nav.megaMenu.tools.textSummarizer"),  href: l("/summarizer") },
      { label: t("common.nav.megaMenu.tools.coverLetterGen"),  href: l("/cover-letter-generator") },
      { label: t("common.nav.megaMenu.tools.hashtagGen"),      href: l("/hashtag-generator") },
      { label: t("common.nav.megaMenu.tools.captionGen"),      href: l("/caption-generator") },
    ],
  },
  {
    category: t("common.nav.megaMenu.categories.colorsDesign"),
    href: l("/categories/color-design-tools"),
    color: "#FFF0F8",
    iconColor: "#C026D3",
    tools: [
      { label: t("common.nav.megaMenu.tools.colorConverter"),   href: l("/color-converter") },
      { label: t("common.nav.megaMenu.tools.hexToRgb"),         href: l("/hex-to-rgb") },
      { label: t("common.nav.megaMenu.tools.colorPaletteGen"),  href: l("/color-palette-generator") },
      { label: t("common.nav.megaMenu.tools.gradientGen"),      href: l("/gradient-generator") },
      { label: t("common.nav.megaMenu.tools.colorNameFinder"),  href: l("/color-name-finder") },
      { label: t("common.nav.megaMenu.tools.aspectRatioCalc"),  href: l("/aspect-ratio-calculator") },
    ],
  },
];
---

<header id="main-nav" class="sticky top-0 z-50 bg-white border-b border-[#E8E6DE]">
  <div class="container">
    <div class="flex items-center justify-between h-[60px] gap-4">

      <!-- ── Logo ── -->
      <a href={l("/")} class="flex items-center shrink-0 no-underline" aria-label="Microapp home">
        <picture>
          <source srcset={logoWebpUrl} type="image/webp" />
          <img
            src={logoPngUrl}
            alt="Microapp"
            width="150"
            height="35"
            style="height:28px;width:auto"
            fetchpriority="high"
          />
        </picture>
      </a>

      <!-- ── Desktop nav (lg+) ── -->
      <nav class="hidden lg:flex items-center gap-1 flex-1" aria-label="Main navigation">

        <!-- Tools mega-menu trigger -->
        <div class="relative group" id="mega-menu-root">
          <button
            id="mega-menu-btn"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="mega-menu-panel"
            class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:text-[#1B6B45] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1B6B45]"
            style="font-family:'Plus Jakarta Sans',sans-serif"
          >
            {t("common.nav.allTools")}
            <svg class="w-4 h-4 transition-transform duration-200 group-[.open]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <!-- Mega-menu panel -->
          <div
            id="mega-menu-panel"
            role="region"
            aria-label="Tool categories"
            class="absolute left-0 top-full mt-1 hidden w-[860px] bg-white border border-[#E8E6DE] rounded-2xl shadow-xl overflow-hidden"
            style="max-width:calc(100vw - 2rem)"
          >
            <div class="flex">
              <!-- Left: category list -->
              <div class="w-52 shrink-0 bg-[#F9F8F4] border-r border-[#E8E6DE] py-3">
                {megaMenu.map((cat, i) => (
                  <button
                    class="mega-cat-btn w-full flex items-center gap-3 px-4 py-2.5 text-sm font-semibold text-gray-700 hover:bg-white hover:text-[#1B6B45] transition-colors text-left"
                    data-cat={i}
                    style="font-family:'Plus Jakarta Sans',sans-serif"
                  >
                    <span
                      class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-base"
                      style={`background:${cat.color}`}
                    >
                      {catIcons[i]}
                    </span>
                    {cat.category}
                  </button>
                ))}
                <div class="border-t border-[#E8E6DE] mt-2 pt-2 px-4">
                  <a href={l("/")} class="text-xs text-[#1B6B45] font-semibold hover:underline" style="font-family:'Plus Jakarta Sans',sans-serif">
                    {t("common.nav.megaMenu.viewAll")}
                  </a>
                </div>
              </div>

              <!-- Right: tools grid for active category -->
              <div class="flex-1 p-5">
                {megaMenu.map((cat, i) => (
                  <div class="mega-cat-panel hidden" data-panel={i}>
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3" style="font-family:'Plus Jakarta Sans',sans-serif">
                      {cat.category}
                    </p>
                    <div class="grid grid-cols-2 gap-1.5">
                      {cat.tools.map(tool => (
                        <a
                          href={tool.href}
                          class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-[#F0FFF4] hover:text-[#1B6B45] transition-colors no-underline"
                          style="font-family:'Plus Jakarta Sans',sans-serif"
                        >
                          <span class="w-1.5 h-1.5 rounded-full bg-[#1B6B45] shrink-0 opacity-50"></span>
                          {tool.label}
                        </a>
                      ))}
                    </div>
                    <div class="mt-4 pt-3 border-t border-[#E8E6DE]">
                      <a href={cat.href} class="text-xs font-semibold text-[#1B6B45] hover:underline" style="font-family:'Plus Jakarta Sans',sans-serif">
                        {t("common.nav.megaMenu.browseAll").replace("{cat}", cat.category)}
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </nav>

      <!-- ── Right side: Language + Auth + Hamburger ── -->
      <div class="flex items-center gap-2 shrink-0">

        <!-- Language switcher (all viewports) -->
        <LanguageSwitcher currentLang={lang} mode="dropdown" client:load />

        <!-- Auth buttons — desktop only -->
        <div class="hidden lg:flex items-center">
          <NavAuthIsland
            loginLabel={t("common.nav.login")}
            signupLabel={t("common.nav.signup")}
            logoutLabel={t("common.nav.logout")}
            myAccountLabel={t("common.nav.myAccount")}
            client:load
          />
        </div>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1B6B45]"
          aria-label={t("common.nav.openMenu")}
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       MOBILE DRAWER  (hidden on lg+)
       ══════════════════════════════════════════════════════════════ -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-[#E8E6DE] bg-white overflow-y-auto"
    style="max-height:calc(100dvh - 60px)"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="container pt-3 pb-6 space-y-1">

      <!-- ── Section label ── -->
      <p class="px-1 pt-1 pb-0.5 text-[0.7rem] font-bold text-gray-400 uppercase tracking-widest" style="font-family:'Plus Jakarta Sans',sans-serif">
        {t("common.nav.categories")}
      </p>

      <!-- ── Accordion categories ── -->
      {megaMenu.map((cat, i) => (
        <div class="mobile-cat-item" data-idx={i}>
          <button
            class="mobile-cat-btn w-full flex items-center justify-between gap-3 px-3 py-3 rounded-xl text-sm font-semibold text-gray-700 hover:bg-[#F0FFF4] hover:text-[#1B6B45] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1B6B45]"
            aria-expanded="false"
            style="font-family:'Plus Jakarta Sans',sans-serif"
          >
            <span class="flex items-center gap-3">
              <span
                class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 text-sm font-bold"
                style={`background:${cat.color};color:${cat.iconColor}`}
              >
                {catIcons[i]}
              </span>
              {cat.category}
            </span>
            <svg
              class="mobile-chevron w-4 h-4 text-gray-400 transition-transform duration-200 shrink-0"
              fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div class="mobile-cat-panel hidden px-3 pb-2">
            <div class="grid grid-cols-2 gap-1.5 pt-1 pb-2">
              {cat.tools.map(tool => (
                <a
                  href={tool.href}
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-gray-600 bg-[#F9F8F4] hover:bg-[#E8F5EE] hover:text-[#1B6B45] transition-colors no-underline"
                  style="font-family:'Plus Jakarta Sans',sans-serif"
                >
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${cat.iconColor};opacity:0.7`}></span>
                  {tool.label}
                </a>
              ))}
            </div>
            <a
              href={cat.href}
              class="inline-flex items-center gap-1 text-xs font-semibold text-[#1B6B45] hover:underline no-underline"
              style="font-family:'Plus Jakarta Sans',sans-serif"
            >
              {t("common.nav.megaMenu.browseAll").replace("{cat}", cat.category)}
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}

      <!-- ── View all tools ── -->
      <a
        href={l("/")}
        class="flex items-center justify-center gap-2 w-full mt-1 px-4 py-3 rounded-xl text-sm font-semibold text-[#1B6B45] bg-[#E8F5EE] hover:bg-[#D1FAE5] transition-colors no-underline"
        style="font-family:'Plus Jakarta Sans',sans-serif"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
        </svg>
        {t("common.nav.megaMenu.viewAll")}
      </a>

      <!-- ── Language picker ── -->
      <div class="pt-3 mt-1 border-t border-[#E8E6DE]">
        <p style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.7rem;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.5rem 0.25rem">
          {t("common.nav.selectLanguage")}
        </p>
        <LanguageSwitcher currentLang={lang} mode="list" client:load />
      </div>

      <!-- ── Auth CTA strip ── -->
      <div class="pt-3 mt-1 border-t border-[#E8E6DE]">
        <NavAuthIsland
          loginLabel={t("common.nav.login")}
          signupLabel={t("common.nav.signup")}
          logoutLabel={t("common.nav.logout")}
          myAccountLabel={t("common.nav.myAccount")}
          client:load
        />
      </div>

    </div>
  </div>
</header>

<!-- Global auth modal -->
<AuthModal client:load />

<script>
  // ── Desktop mega-menu ──────────────────────────────────────────────────────
  const megaBtn   = document.getElementById('mega-menu-btn') as HTMLButtonElement | null;
  const megaPanel = document.getElementById('mega-menu-panel') as HTMLElement | null;
  const megaRoot  = document.getElementById('mega-menu-root') as HTMLElement | null;
  const catBtns   = document.querySelectorAll<HTMLButtonElement>('.mega-cat-btn');
  const catPanels = document.querySelectorAll<HTMLElement>('.mega-cat-panel');

  let activeIdx = 0;

  function showPanel(idx: number) {
    catPanels.forEach((p, i) => p.classList.toggle('hidden', i !== idx));
    catBtns.forEach((b, i) => {
      b.classList.toggle('bg-white', i === idx);
      b.classList.toggle('text-[#1B6B45]', i === idx);
    });
    activeIdx = idx;
  }

  function openMega() {
    megaPanel?.classList.remove('hidden');
    megaRoot?.classList.add('open');
    megaBtn?.setAttribute('aria-expanded', 'true');
    showPanel(activeIdx);
  }

  function closeMega() {
    megaPanel?.classList.add('hidden');
    megaRoot?.classList.remove('open');
    megaBtn?.setAttribute('aria-expanded', 'false');
  }

  megaBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    megaPanel?.classList.contains('hidden') ? openMega() : closeMega();
  });

  catBtns.forEach((btn, i) => {
    btn.addEventListener('mouseenter', () => showPanel(i));
    btn.addEventListener('click', () => showPanel(i));
  });

  document.addEventListener('click', (e) => {
    if (!megaRoot?.contains(e.target as Node)) closeMega();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeMega(); closeMobileMenu(); }
  });

  // ── Mobile hamburger ───────────────────────────────────────────────────────
  const mobileBtn  = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  const hamburger  = document.getElementById('hamburger-icon') as SVGElement | null;
  const closeIcon  = document.getElementById('close-icon') as SVGElement | null;

  function closeMobileMenu() {
    mobileMenu?.classList.add('hidden');
    hamburger?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    mobileBtn?.setAttribute('aria-expanded', 'false');
  }

  mobileBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      closeMobileMenu();
    } else {
      mobileMenu?.classList.remove('hidden');
      hamburger?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      mobileBtn?.setAttribute('aria-expanded', 'true');
    }
  });

  // ── Mobile accordion categories ────────────────────────────────────────────
  const mobileCatBtns = document.querySelectorAll<HTMLButtonElement>('.mobile-cat-btn');

  mobileCatBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const item   = btn.closest('.mobile-cat-item') as HTMLElement | null;
      const panel  = item?.querySelector<HTMLElement>('.mobile-cat-panel');
      const chev   = btn.querySelector<SVGElement>('.mobile-chevron');
      const isOpen = !panel?.classList.contains('hidden');

      document.querySelectorAll<HTMLElement>('.mobile-cat-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll<HTMLButtonElement>('.mobile-cat-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        b.querySelector<SVGElement>('.mobile-chevron')?.style.setProperty('transform', '');
      });

      if (!isOpen) {
        panel?.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        if (chev) chev.style.transform = 'rotate(180deg)';
        setTimeout(() => panel?.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
      }
    });
  });
</script>
