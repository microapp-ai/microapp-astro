---
/**
 * HomeFooter.astro — Shared footer used on all pages
 * Accepts an optional lang prop; defaults to "en"
 */
import { useTranslations, localizeUrl } from "../i18n/utils";
import { type Locale } from "../i18n/config";

interface Props { lang?: Locale; }
const { lang = "en" } = Astro.props;
const t = await useTranslations(lang);
const l = (path: string) => localizeUrl(path, lang);

const logoWebpUrl = "/images/microapp-logo-optimized.webp";
const logoPngUrl  = "/images/microapp-logo-optimized.png";

const categories = [
  { label: t("common.footer.catText"),       href: l("/categories/text-tools"),         icon: "T" },
  { label: t("common.footer.catNumbers"),    href: l("/categories/number-calculators"),  icon: "#" },
  { label: t("common.footer.catTime"),       href: l("/categories/time-date-tools"),    icon: "⏱" },
  { label: t("common.footer.catGenerators"), href: l("/categories/generators"),         icon: "⚡" },
  { label: t("common.footer.catDev"),        href: l("/categories/dev-tools"),          icon: "></"},
  { label: t("common.footer.catWriting"),    href: l("/categories/writing-ai"),         icon: "✍" },
  { label: t("common.footer.catColors"),     href: l("/categories/color-design-tools"), icon: "🎨" },
];

const popularTools = [
  { label: t("common.footer.toolWordCounter"),       href: l("/word-counter") },
  { label: t("common.footer.toolAgeCalculator"),     href: l("/age-calculator") },
  { label: t("common.footer.toolPasswordGenerator"), href: l("/password-generator") },
  { label: t("common.footer.toolJsonFormatter"),     href: l("/json-formatter") },
  { label: t("common.footer.toolUnitConverter"),     href: l("/unit-converter") },
  { label: t("common.footer.toolPercentageCalc"),    href: l("/percentage-calculator") },
  { label: t("common.footer.toolQrCodeReader"),      href: l("/qr-code-reader") },
  { label: t("common.footer.toolColorConverter"),    href: l("/color-converter") },
];

const company = [
  { label: t("common.footer.companyAbout"),   href: l("/about") },
  { label: t("common.footer.companyPrivacy"), href: l("/privacy-policy") },
  { label: t("common.footer.companyTerms"),   href: l("/terms-of-service") },
];

const trustBadges = [
  { icon: "🔒", text: t("common.footer.privacyFirst") },
  { icon: "⚡", text: t("common.footer.instantResults") },
  { icon: "🆓", text: t("common.footer.alwaysFree") },
];

const stats = [
  { value: "136+", label: t("common.footer.freeTools") },
  { value: "0",    label: t("common.footer.signupsRequired") },
  { value: "0",    label: t("common.footer.adsOnTools") },
  { value: "100%", label: t("common.footer.browserBased") },
];
---

<footer style="background:#111827;color:white">

  <!-- ── Top strip: logo + tagline ── -->
  <div style="border-bottom:1px solid #1F2937;padding:3rem 0 2.5rem">
    <div class="container grid md:grid-cols-2 gap-10 items-start">

      <!-- Left: logo + tagline -->
      <div>
        <a href={l("/")} style="display:inline-block;margin-bottom:1.25rem">
          <picture>
            <source srcset={logoWebpUrl} type="image/webp" />
            <img
              src={logoPngUrl}
              alt="Microapp"
              width="140"
              height="32"
              style="height:26px;width:auto;filter:brightness(0) invert(1)"
            />
          </picture>
        </a>
        <p style="font-family:'Inter',sans-serif;font-size:0.95rem;color:#9CA3AF;line-height:1.7;max-width:36ch;margin:0 0 1.25rem">
          {t("common.footer.tagline")}
        </p>
        <!-- Trust badges -->
        <div style="display:flex;flex-wrap:wrap;gap:0.625rem">
          {trustBadges.map(b => (
            <span style="display:inline-flex;align-items:center;gap:0.375rem;padding:0.3rem 0.75rem;background:#1F2937;border-radius:9999px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.75rem;font-weight:600;color:#D1D5DB">
              {b.icon} {b.text}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: CTA -->
      <div style="background:#1F2937;border-radius:1.25rem;padding:1.75rem">
        <p style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:1rem;color:white;margin:0 0 0.375rem">
          {t("common.footer.newTools")}
        </p>
        <p style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;margin:0 0 1.25rem;line-height:1.6">
          {t("common.footer.newToolsDesc")}
        </p>
        <a
          href={l("/")}
          style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.65rem 1.25rem;background:#1B6B45;border-radius:0.75rem;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.875rem;color:white;text-decoration:none;transition:background 0.15s"
          class="hover:bg-[#155538]"
        >
          <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
          </svg>
          {t("common.footer.browseAll")}
        </a>
      </div>

    </div>
  </div>

  <!-- ── Link grid ── -->
  <div style="padding:2.5rem 0">
    <div class="container grid sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Categories -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          {t("common.footer.categories")}
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem">
          {categories.map(c => (
            <li>
              <a
                href={c.href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;text-decoration:none;display:flex;align-items:center;gap:0.5rem;transition:color 0.15s"
                class="hover:text-white"
              >
                <span style="font-size:0.8rem;opacity:0.7">{c.icon}</span>
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular Tools -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          {t("common.footer.popularTools")}
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem">
          {popularTools.map(tool => (
            <li>
              <a
                href={tool.href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;text-decoration:none;transition:color 0.15s"
                class="hover:text-white"
              >
                {tool.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          {t("common.footer.company")}
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem">
          {company.map(c => (
            <li>
              <a
                href={c.href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;text-decoration:none;transition:color 0.15s"
                class="hover:text-white"
              >
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Stats / highlights -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          {t("common.footer.byTheNumbers")}
        </h3>
        <div style="display:flex;flex-direction:column;gap:1rem">
          {stats.map(s => (
            <div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:1.5rem;color:#FFE234;line-height:1">{s.value}</div>
              <div style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#6B7280;margin-top:0.1rem">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div style="border-top:1px solid #1F2937;padding:1.5rem 0">
    <div class="container flex flex-col sm:flex-row items-center justify-between gap-3">
      <p style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;margin:0">
        © {new Date().getFullYear()} Microapp. {t("common.footer.allRightsReserved")}
      </p>
      <div style="display:flex;align-items:center;gap:1.5rem">
        <a href={l("/privacy-policy")} style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;text-decoration:none;transition:color 0.15s" class="hover:text-white">{t("common.footer.privacy")}</a>
        <a href={l("/terms-of-service")} style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;text-decoration:none;transition:color 0.15s" class="hover:text-white">{t("common.footer.terms")}</a>
        <a href={l("/about")} style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;text-decoration:none;transition:color 0.15s" class="hover:text-white">{t("common.footer.about")}</a>
        <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563">{t("common.footer.madeWith")}</span>
      </div>
    </div>
  </div>

</footer>
