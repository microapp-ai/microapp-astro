---
/**
 * HomeFooter.astro — Improved home page footer
 */
import { localizeUrl } from "../i18n/utils";
import { type Locale } from "../i18n/config";

interface Props { lang?: Locale; }
const { lang = "en" } = Astro.props;
const l = (path: string) => localizeUrl(path, lang);

const logoWebpUrl = "/images/microapp-logo-optimized.webp";
const logoPngUrl  = "/images/microapp-logo-optimized.png";

const categories = [
  { label: "Text Tools",      href: l("/#text"),       icon: "T" },
  { label: "Numbers",         href: l("/#numbers"),    icon: "#" },
  { label: "Time & Date",     href: l("/#time"),       icon: "⏱" },
  { label: "Generators",      href: l("/#generators"), icon: "⚡" },
  { label: "Dev Tools",       href: l("/#dev"),        icon: "</>" },
  { label: "Writing & AI",    href: l("/#writing"),    icon: "✍" },
  { label: "Colors & Design", href: l("/#design"),     icon: "🎨" },
];

const popularTools = [
  { label: "Word Counter",        href: l("/word-counter") },
  { label: "Age Calculator",      href: l("/age-calculator") },
  { label: "Password Generator",  href: l("/password-generator") },
  { label: "JSON Formatter",      href: l("/json-formatter") },
  { label: "Unit Converter",      href: l("/unit-converter") },
  { label: "Percentage Calc",     href: l("/percentage-calculator") },
  { label: "QR Code Reader",      href: l("/qr-code-reader") },
  { label: "Color Converter",     href: l("/color-converter") },
];

const company = [
  { label: "About",          href: "/about" },
  { label: "Privacy Policy", href: "/privacy-policy" },
  { label: "Terms of Service", href: "/terms-of-service" },
];
---

<footer style="background:#111827;color:white">

  <!-- ── Top strip: logo + tagline ── -->
  <div style="border-bottom:1px solid #1F2937;padding:3rem 0 2.5rem">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-10 items-start">

      <!-- Left: logo + tagline -->
      <div>
        <a href="/" style="display:inline-block;margin-bottom:1.25rem">
          <picture>
            <source srcset={logoWebpUrl} type="image/webp" />
            <img
              src={logoPngUrl}
              alt="Microapp"
              width="140"
              height="32"
              style="height:26px;width:auto;filter:brightness(0) invert(1)"
            />
          </picture>
        </a>
        <p style="font-family:'Inter',sans-serif;font-size:0.95rem;color:#9CA3AF;line-height:1.7;max-width:36ch;margin:0 0 1.25rem">
          136+ free online utility tools — no account needed, no ads on tools, no tracking of your inputs.
        </p>
        <!-- Trust badges -->
        <div style="display:flex;flex-wrap:wrap;gap:0.625rem">
          {[
            { icon: "🔒", text: "Privacy-first" },
            { icon: "⚡", text: "Instant results" },
            { icon: "🆓", text: "Always free" },
          ].map(b => (
            <span style="display:inline-flex;align-items:center;gap:0.375rem;padding:0.3rem 0.75rem;background:#1F2937;border-radius:9999px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.75rem;font-weight:600;color:#D1D5DB">
              {b.icon} {b.text}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: newsletter / CTA -->
      <div style="background:#1F2937;border-radius:1.25rem;padding:1.75rem">
        <p style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:1rem;color:white;margin:0 0 0.375rem">
          New tools added every week
        </p>
        <p style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;margin:0 0 1.25rem;line-height:1.6">
          Browse all categories and bookmark your favourites — no email required.
        </p>
        <a
          href="/"
          style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.65rem 1.25rem;background:#1B6B45;border-radius:0.75rem;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.875rem;color:white;text-decoration:none;transition:background 0.15s"
          class="hover:bg-[#155538]"
        >
          <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
          </svg>
          Browse all 136 tools
        </a>
      </div>

    </div>
  </div>

  <!-- ── Link grid ── -->
  <div style="padding:2.5rem 0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Categories -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          Categories
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem">
          {categories.map(c => (
            <li>
              <a
                href={c.href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;text-decoration:none;display:flex;align-items:center;gap:0.5rem;transition:color 0.15s"
                class="hover:text-white"
              >
                <span style="font-size:0.8rem;opacity:0.7">{c.icon}</span>
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular Tools -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          Popular Tools
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem">
          {popularTools.map(t => (
            <li>
              <a
                href={t.href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;text-decoration:none;transition:color 0.15s"
                class="hover:text-white"
              >
                {t.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          Company
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem">
          {company.map(c => (
            <li>
              <a
                href={c.href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#9CA3AF;text-decoration:none;transition:color 0.15s"
                class="hover:text-white"
              >
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Stats / highlights -->
      <div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 1rem">
          By the numbers
        </h3>
        <div style="display:flex;flex-direction:column;gap:1rem">
          {[
            { value: "136+", label: "Free tools" },
            { value: "0",    label: "Signups required" },
            { value: "0",    label: "Ads on tools" },
            { value: "100%", label: "Browser-based" },
          ].map(s => (
            <div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:1.5rem;color:#FFE234;line-height:1">{s.value}</div>
              <div style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#6B7280;margin-top:0.1rem">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div style="border-top:1px solid #1F2937;padding:1.5rem 0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;margin:0">
        © {new Date().getFullYear()} Microapp. All rights reserved.
      </p>
      <div style="display:flex;align-items:center;gap:1.5rem">
        <a href="/privacy-policy" style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;text-decoration:none;transition:color 0.15s" class="hover:text-white">Privacy</a>
        <a href="/terms-of-service" style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;text-decoration:none;transition:color 0.15s" class="hover:text-white">Terms</a>
        <a href="/about" style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563;text-decoration:none;transition:color 0.15s" class="hover:text-white">About</a>
        <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#4B5563">Made with ♥ for the web</span>
      </div>
    </div>
  </div>

</footer>
