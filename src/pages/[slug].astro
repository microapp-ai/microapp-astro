---
export const prerender = true;

/**
 * [slug].astro — Dynamic route that generates one static HTML page per tool (English)
 *
 * Locale-prefixed versions (e.g. /es/word-counter) are generated by
 * src/pages/[lang]/[slug].astro.
 */
import ToolLayout from "../layouts/ToolLayout.astro";
import ToolIsland from "../components/ToolIsland";
import FaqAccordion from "../components/FaqAccordion";
import ToolRatings from "../components/ToolRatings";
import AuthModal from "../components/AuthModal";
import { getAllTools } from "../lib/supabase";
import { NON_DEFAULT_LOCALES } from "../i18n/config";
import type { ToolMetadata } from "../lib/types";

const siteUrl = "https://microapp.io";

export async function getStaticPaths() {
  const tools = await getAllTools();
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

interface Props {
  tool: ToolMetadata;
}

const { tool } = Astro.props;

const hreflangAlternates = [
  { hreflang: "x-default", href: `${siteUrl}/${tool.slug}` },
  { hreflang: "en",        href: `${siteUrl}/${tool.slug}` },
  ...NON_DEFAULT_LOCALES.map(l => ({
    hreflang: l,
    href: `${siteUrl}/${l}/${tool.slug}`,
  })),
];
---

<ToolLayout tool={tool} lang="en" dir="ltr" hreflangAlternates={hreflangAlternates}>
  <div slot="tool-widget">
    <ToolIsland slug={tool.slug} client:load />
  </div>

  {tool.faqs && tool.faqs.length > 0 && (
    <div slot="faq-accordion">
      <FaqAccordion faqs={tool.faqs} client:visible />
    </div>
  )}

  <div slot="ratings">
    <ToolRatings slug={tool.slug} client:visible />
  </div>

  <AuthModal client:load />
</ToolLayout>
